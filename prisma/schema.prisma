generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String  @id @default(cuid())
  name               String?
  email              String  @unique
  password           String?
  role               String  @default("USER")
  schoolId           String?
  subscriptionStatus String  @default("TRIAL")
  School             School? @relation(fields: [schoolId], references: [id])
}

model Client {
  id       String    @id @default(cuid())
  name     String
  schoolId String
  School   School    @relation(fields: [schoolId], references: [id])
  Invoice  Invoice[]
}

model Invoice {
  id        String   @id
  amount    Float
  clientId  String
  schoolId  String
  createdAt DateTime @default(now())
  Client    Client   @relation(fields: [clientId], references: [id])
  School    School   @relation(fields: [schoolId], references: [id])
}

model School {
  id        String    @id @default(cuid())
  name      String
  createdAt DateTime  @default(now())
  Client    Client[]
  Invoice   Invoice[]
  User      User[]
}

model playing_with_neon {
  id    Int    @id @default(autoincrement())
  name  String
  value Float? @db.Real
}
