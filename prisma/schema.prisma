generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id                 String @id @default(cuid())
  email              String @unique
  password           String
  role               String @default("USER")
  schoolId           String?

  subscriptionStatus String @default("FREE")
}

model Client {
  id        String @id @default(cuid())
  name      String
  schoolId  String
}

model Invoice {
  id        String @id @default(cuid())
  amount    Float
  status    String @default("PENDING")
  clientId  String
  createdAt DateTime @default(now())
}

model School {
  id    String @id @default(cuid())
  name  String
}